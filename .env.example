# GaiaLynk V1.3.1 mainline (Railway / local) — placeholders only.
# Copy to `.env` locally; NEVER commit real values.
# See also: packages/website/.env.example (Vercel / Next.js).
# Migration max sequence: 0035 (0035_oauth_workspace_name.sql)

# ============================================================
# §1 CORE — required for any deployment
# ============================================================
# PORT=3000
# NODE_ENV=production
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE
REDIS_URL=redis://HOST:6379

# JWT for access tokens — MUST be ≥16 chars in production
JWT_SECRET=replace-with-long-random-string-min-16-chars

# ============================================================
# §2 CONNECTORS — required for production connector features
# ============================================================
# AES-256-GCM encryption for OAuth tokens at rest (≥32 chars)
CONNECTOR_TOKEN_ENCRYPTION_KEY=replace-with-long-random-string-min-32-chars
# Desktop Connector pairing / device trust (≥16 chars)
DESKTOP_CONNECTOR_PAIRING_SECRET=replace-with-strong-random-secret
# HMAC salt for external action receipts (avoid built-in default in prod)
EXTERNAL_RECEIPT_SECRET=replace-with-strong-random-secret
# Optional; falls back to JWT_SECRET
# CONNECTOR_OAUTH_STATE_SECRET=

# ============================================================
# §3 OAUTH — set when enabling cloud connectors
# ============================================================
# --- Google Calendar ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://YOUR_MAINLINE_HOST/api/v1/connectors/cloud/oauth/callback/google-calendar

# --- Notion ---
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# NOTION_OAUTH_REDIRECT_URI=https://YOUR_MAINLINE_HOST/api/v1/connectors/cloud/oauth/callback/notion

# Browser redirect after OAuth completion (supports {locale} placeholder)
# CONNECTOR_OAUTH_SUCCESS_REDIRECT_URL=https://YOUR_WEBSITE_HOST/{locale}/app/settings/connectors/oauth-complete

# ============================================================
# §4 EMAIL NOTIFICATIONS (V1.3.1 E-16)
# ============================================================
# Resend API key — omit to disable email delivery
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# Base URL for deep links in email CTAs
# GAIALYNK_APP_BASE_URL=https://app.example.com

# ============================================================
# §5 ADMIN & FOUNDER ACCESS CONTROL
# ============================================================
# Comma-separated user UUIDs for Founder Dashboard access
# FOUNDER_DASHBOARD_USER_IDS=
# Comma-separated user UUIDs for directory ranking config PATCH
# DIRECTORY_RANKING_ADMIN_USER_IDS=

# ============================================================
# §6 RATE LIMITING (V1.3.1 E-18)
# ============================================================
# RATE_LIMIT_REGISTER_PER_HOUR=10
# RATE_LIMIT_MESSAGE_PER_MIN=30
# RATE_LIMIT_DIRECTORY_SEARCH_PER_MIN=60
# RATE_LIMIT_INVOCATION_PER_HOUR=120

# ============================================================
# §7 ORCHESTRATION & SCHEDULING (V1.3 E-5, V1.3.1 E-14)
# ============================================================
# A2A request timeout in ms (default varies by code path)
# A2A_REQUEST_TIMEOUT_MS=30000
# Disable scheduler loop (useful for multi-instance before leader election)
# DISABLE_ORCHESTRATION_SCHEDULER=1
# Optional LLM for intent routing (keyword heuristic if unset)
# OPENAI_API_KEY=
# OPENAI_ORCHESTRATION_MODEL=gpt-4o

# ============================================================
# §8 DATA RETENTION (V1.3.1 E-17)
# ============================================================
# Enable 24h archival job (single instance only)
# DATA_RETENTION_JOB_ENABLED=1
# Override per-table TTL in days
# DATA_RETENTION_MESSAGES_DAYS=365
# DATA_RETENTION_AUDIT_EVENTS_DAYS=730
# DATA_RETENTION_RECEIPTS_DAYS=365
# DATA_RETENTION_INVOCATIONS_DAYS=365
# DATA_RETENTION_ORCHESTRATION_RUNS_DAYS=365
# DATA_RETENTION_EXTERNAL_ACTION_RECEIPTS_DAYS=365

# ============================================================
# §9 TRUST & REPUTATION (V1.3 E-6)
# ============================================================
# Sliding window thresholds for agent retest queue
# AGENT_FEEDBACK_RETEST_THRESHOLD=3
# AGENT_FEEDBACK_RETEST_WINDOW_DAYS=30

# ============================================================
# §10 OPTIONAL TOGGLES
# ============================================================
# NOTION_MOCK=true
# CONNECTOR_CLOUD_STUB=1
# FAIL_FAST_CONFIG=1
# REQUIRE_DATABASE_URL=1
# CONNECTOR_UPLOAD_DIR=/path/to/persistent/uploads
# CONNECTOR_UPLOAD_MAX_BYTES=10485760
