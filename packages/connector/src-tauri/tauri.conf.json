{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GaiaLynk Connector",
  "version": "0.1.0",
  "identifier": "com.gaialynk.connector",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://127.0.0.1:* https: wss:; img-src 'self' data: asset: blob:; style-src 'self' 'unsafe-inline'",
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "title": "GaiaLynk Connector",
        "width": 460,
        "height": 640,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
