{
  "name": "@gaialynk/website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/check-env.mjs && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:governance": "vitest run --config vitest.config.ts tests/promise-consistency-gate.test.ts tests/entry-governance-consistency.test.ts tests/website-entry-coverage.test.ts tests/sitemap-entry-routes.test.ts tests/api-health-gate.test.ts tests/terminology-governance.test.ts",
    "test:integration:mainline-proxy": "vitest run --config vitest.config.ts tests/mainline-proxy.test.ts",
    "release:gate": "npm run typecheck && npm run test:governance && npm run test:integration:mainline-proxy",
    "analytics:migrate": "node scripts/migrate-analytics.mjs",
    "analytics:cleanup": "node scripts/cleanup-analytics.mjs"
  },
  "dependencies": {
    "next": "^15.3.1",
    "pg": "^8.16.3",
    "posthog-js": "^1.254.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3"
  }
}
