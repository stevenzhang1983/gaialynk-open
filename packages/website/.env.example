# Copy to `.env.local` for local dev. In Vercel: Project → Settings → Environment Variables.
# Before custom domain: use your Vercel URL (e.g. https://<project>.vercel.app). After: https://www.example.com + Redeploy.

NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Production build (NODE_ENV=production) requires this — no trailing slash.
MAINLINE_API_URL=https://your-mainline.up.railway.app

# Optional: Desktop Connector download page (GitHub Releases). Defaults to open-core repo if unset.
# NEXT_PUBLIC_DESKTOP_CONNECTOR_RELEASES_URL=https://github.com/GaiaLynk/gaialynk-A2A/releases
#
# 本地同时跑「主网 + 官网」时（避免产品区 /api/mainline/* 出现 502）：
# 1) 仓库根目录：DATABASE_URL=postgres://… npm run dev:server   → 默认 http://127.0.0.1:3000
# 2) packages/website：复制本文件为 .env.local，并取消下一行注释（或自行设为 3000 上的主网地址）
# MAINLINE_API_URL=http://127.0.0.1:3000
# 若官网用 next dev -p 3001，主网仍应占 3000；代理会连 MAINLINE_API_URL，与官网端口无关。
