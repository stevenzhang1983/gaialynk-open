{
  "name": "gaialynk.com",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev:server": "node --import tsx packages/server/src/index.ts",
    "dev:console": "python -m http.server 5173 -d packages/console",
    "dev:website": "npm --prefix packages/website run dev",
    "analytics:migrate:website": "npm --prefix packages/website run analytics:migrate",
    "analytics:cleanup:website": "npm --prefix packages/website run analytics:cleanup",
    "demo:phase0": "./scripts/demo-phase0.sh",
    "db:migrate": "node --import tsx packages/server/src/infra/db/migrate.ts",
    "db:reset": "node --import tsx packages/server/src/infra/db/reset.ts",
    "db:seed": "node --import tsx packages/server/src/infra/db/seed.ts",
    "verify:pg:local": "./scripts/verify-pg-local.sh",
    "bootstrap:pg:local": "./scripts/bootstrap-pg-local.sh",
    "release:preflight:mainline": "./scripts/mainline-preflight.sh",
    "release:smoke:mainline": "node --import tsx scripts/mainline-post-release-smoke.ts",
    "release:weekly:ops-evidence:mainline": "./scripts/mainline-weekly-ops-evidence.sh",
    "contracts:drift:mainline": "node --import tsx scripts/mainline-contract-drift-report.ts",
    "contracts:init-baseline:mainline": "node --import tsx scripts/mainline-contract-drift-report.ts --init-baseline",
    "build:website": "npm --prefix packages/website run build",
    "test:website": "npm --prefix packages/website run test",
    "test:website:governance": "npm --prefix packages/website run test:governance",
    "release:gate:website": "npm --prefix packages/website run release:gate",
    "test": "vitest run",
    "test:contracts:mainline": "vitest run packages/server/tests/mainline-contract-compatibility.test.ts",
    "test:pg": "vitest run packages/server/tests/postgres-integration.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:website": "npm --prefix packages/website run typecheck"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.7",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
